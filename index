<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>SAO AR Interface</title>
    
    <script src="https://cdn.jsdelivr.net/npm/@mediapipe/camera_utils/camera_utils.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/@mediapipe/hands/hands.js" crossorigin="anonymous"></script>
    
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;700&display=swap');

        :root {
            --sao-orange: #ff9d00;
            --sao-bg: rgba(245, 245, 245, 0.7);
            --sao-border: rgba(200, 200, 200, 0.9);
            --sao-dark: #333;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            user-select: none;
            font-family: 'Rajdhani', sans-serif;
        }

        body {
            background-color: #000;
            overflow: hidden;
            width: 100vw;
            height: 100vh;
        }

        /* Camera Background */
        #environment-video {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            z-index: 1;
        }

        /* Initialization Screen */
        #init-screen {
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,0.9);
            z-index: 1000;
            display: flex;
            justify-content: center;
            align-items: center;
            flex-direction: column;
            color: #fff;
        }

        #link-start-btn {
            background: transparent;
            border: 2px solid var(--sao-orange);
            color: var(--sao-orange);
            font-size: 2rem;
            padding: 15px 40px;
            font-family: 'Rajdhani', sans-serif;
            text-transform: uppercase;
            cursor: pointer;
            box-shadow: 0 0 15px rgba(255, 157, 0, 0.5);
            transition: all 0.3s;
        }

        #link-start-btn:active {
            background: var(--sao-orange);
            color: #fff;
        }

        /* 3D AR Scene Container */
        #scene {
            position: absolute;
            top: 0; left: 0;
            width: 100vw; height: 100vh;
            perspective: 800px;
            z-index: 10;
            pointer-events: none; /* Let clicks pass through */
        }

        /* The floating UI container anchored in space */
        #ar-anchor {
            position: absolute;
            top: 50%; left: 50%;
            width: 350px;
            transform-style: preserve-3d;
            /* Center the anchor point */
            margin-left: -175px; 
            margin-top: -200px;
            /* Drop shadow simulates AR depth against the real world */
            filter: drop-shadow(10px 20px 15px rgba(0,0,0,0.8));
            transition: transform 0.1s linear;
            pointer-events: auto; /* Re-enable interaction for UI */
        }

        /* Base UI Styles */
        .glass-panel {
            background: var(--sao-bg);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.6);
            border-radius: 4px;
            padding: 15px;
            color: var(--sao-dark);
            margin-bottom: 15px;
            box-shadow: inset 0 0 10px rgba(255,255,255,0.5);
        }

        .panel-header {
            font-size: 1.2rem;
            border-bottom: 2px solid var(--sao-orange);
            margin-bottom: 10px;
            text-transform: uppercase;
            display: flex;
            justify-content: space-between;
        }

        .list-item {
            display: flex;
            justify-content: space-between;
            margin-bottom: 5px;
            font-size: 1rem;
            font-weight: bold;
        }

        .val { color: var(--sao-orange); }

        /* MediaPipe Cursor */
        #ar-cursor {
            position: absolute;
            width: 20px; height: 20px;
            border: 2px solid #00ff00;
            border-radius: 50%;
            transform: translate(-50%, -50%);
            z-index: 500;
            pointer-events: none;
            display: none;
            box-shadow: 0 0 10px #00ff00;
        }
        
        #ar-cursor::after {
            content: '';
            position: absolute;
            top: 50%; left: 50%;
            width: 4px; height: 4px;
            background: #00ff00;
            border-radius: 50%;
            transform: translate(-50%, -50%);
        }

        .pinched {
            background: rgba(0, 255, 0, 0.4);
            transform: translate(-50%, -50%) scale(0.8) !important;
        }

        /* Buttons */
        .sao-btn {
            display: inline-block;
            background: #ddd;
            border: 1px solid #aaa;
            padding: 5px 10px;
            cursor: pointer;
            margin-top: 10px;
        }
        .sao-btn:hover, .sao-btn.active-click {
            background: var(--sao-orange);
            color: white;
            border-color: white;
        }

    </style>
</head>
<body>

    <div id="init-screen">
        <h2 style="margin-bottom: 20px; text-shadow: 0 0 10px var(--sao-orange);">NEVEGEAR CALIBRATION</h2>
        <button id="link-start-btn" onclick="startAR()">LINK START</button>
        <p style="margin-top: 20px; font-size: 0.9rem; opacity: 0.7;">Requires Camera & Motion Sensors</p>
    </div>

    <video id="environment-video" autoplay playsinline></video>

    <div id="ar-cursor"></div>

    <div id="scene">
        <div id="ar-anchor">
            
            <div class="glass-panel">
                <div class="panel-header"><span>Status</span><span id="clock">00:00</span></div>
                <div class="list-item"><span>HP (Battery):</span><span class="val" id="bat-val">100%</span></div>
                <div class="list-item"><span>Location:</span><span class="val" id="loc-val">Scanning...</span></div>
                <button class="sao-btn" id="ping-btn">Ping Server</button>
            </div>

            <div class="glass-panel">
                <div class="panel-header">Diagnostics</div>
                <div class="list-item"><span>Device Mem:</span><span class="val" id="mem-val">--</span></div>
                <div class="list-item"><span>Cores:</span><span class="val" id="core-val">--</span></div>
                <div class="list-item"><span>Network:</span><span class="val" id="net-val">--</span></div>
            </div>

            <div class="glass-panel">
                <div class="panel-header">World Data</div>
                <p id="fact-display" style="font-size: 0.9rem; font-weight: 500;">Connecting to cardinal system...</p>
                <button class="sao-btn" id="next-fact-btn">Cycle Data</button>
            </div>

        </div>
    </div>

    <script>
        const AudioContext = window.AudioContext || window.webkitAudioContext;
        let audioCtx;
        function playSfx(type) {
            if(!audioCtx) audioCtx = new AudioContext();
            if(audioCtx.state === 'suspended') audioCtx.resume();
            
            const osc = audioCtx.createOscillator();
            const gain = audioCtx.createGain();
            osc.connect(gain);
            gain.connect(audioCtx.destination);
            
            const now = audioCtx.currentTime;
            if (type === 'click') {
                osc.type = 'sine';
                osc.frequency.setValueAtTime(1500, now);
                osc.frequency.exponentialRampToValueAtTime(500, now + 0.05);
                gain.gain.setValueAtTime(0.5, now);
                gain.gain.exponentialRampToValueAtTime(0.01, now + 0.05);
                osc.start(now);
                osc.stop(now + 0.05);
            }
        }
    </script>

    <script>
        // --- 1. UI Logic & Widgets ---
        setInterval(() => {
            document.getElementById('clock').innerText = new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
        }, 1000);

        navigator.getBattery?.().then(b => {
            document.getElementById('bat-val').innerText = Math.floor(b.level * 100) + '%';
        });

        document.getElementById('mem-val').innerText = navigator.deviceMemory ? `>= ${navigator.deviceMemory} GB` : 'Hidden';
        document.getElementById('core-val').innerText = navigator.hardwareConcurrency || 'Hidden';
        document.getElementById('net-val').innerText = navigator.connection?.effectiveType || 'Offline';

        const facts = [
            "The first computer bug was an actual real moth.",
            "A single fiber optic cable can carry 100 Terabits per second.",
            "Your smartphone has more processing power than the Apollo 11 moon lander.",
            "There are over 4 billion active internet users worldwide."
        ];
        let factIdx = 0;
        document.getElementById('next-fact-btn').addEventListener('click', (e) => {
            playSfx('click');
            factIdx = (factIdx + 1) % facts.length;
            document.getElementById('fact-display').innerText = facts[factIdx];
        });

        document.getElementById('ping-btn').addEventListener('click', () => {
            playSfx('click');
            document.getElementById('ping-btn').innerText = "Pong!";
            setTimeout(() => document.getElementById('ping-btn').innerText = "Ping Server", 1000);
        });

        // GPS Location
        navigator.geolocation.getCurrentPosition(
            (pos) => document.getElementById('loc-val').innerText = `${pos.coords.latitude.toFixed(2)}, ${pos.coords.longitude.toFixed(2)}`,
            () => document.getElementById('loc-val').innerText = "Signal Lost"
        );


        // --- 2. System Initialization (LINK START) ---
        async function startAR() {
            playSfx('click');
            document.getElementById('init-screen').style.display = 'none';

            // Start Camera
            const videoElement = document.getElementById('environment-video');
            try {
                const stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } });
                videoElement.srcObject = stream;
                
                // Initialize MediaPipe AI once camera is ready
                initMediaPipe(videoElement);
            } catch (err) {
                alert("Camera access denied or unavailable.");
            }

            // Start Spatial Anchoring (Gyroscope)
            initGyrosensor();
        }

        // --- 3. Spatial Anchoring (3DoF Device Orientation) ---
        let baseAlpha = null;
        function initGyrosensor() {
            // Request permission for iOS 13+ devices
            if (typeof DeviceOrientationEvent.requestPermission === 'function') {
                DeviceOrientationEvent.requestPermission().then(permissionState => {
                    if (permissionState === 'granted') {
                        window.addEventListener('deviceorientation', handleOrientation);
                    }
                }).catch(console.error);
            } else {
                // Non-iOS devices
                window.addEventListener('deviceorientation', handleOrientation);
            }
        }

        function handleOrientation(event) {
            if (baseAlpha === null) baseAlpha = event.alpha; // Set physical zero point

            // Calculate difference from starting position
            let alpha = event.alpha - baseAlpha; 
            let beta = event.beta - 90; // Adjust so holding phone upright is 0
            let gamma = event.gamma;

            // Apply inverse rotation to the UI container to make it "stick" in the real world
            const arAnchor = document.getElementById('ar-anchor');
            arAnchor.style.transform = `translateZ(-500px) rotateY(${-alpha}deg) rotateX(${-beta}deg) rotateZ(${-gamma}deg)`;
        }


        // --- 4. MediaPipe Hand Tracking (AI Pinch to Click) ---
        const cursor = document.getElementById('ar-cursor');
        let isPinching = false;

        function initMediaPipe(video) {
            const hands = new Hands({locateFile: (file) => {
                return `https://cdn.jsdelivr.net/npm/@mediapipe/hands/${file}`;
            }});
            
            hands.setOptions({
                maxNumHands: 1,
                modelComplexity: 1,
                minDetectionConfidence: 0.7,
                minTrackingConfidence: 0.7
            });
            
            hands.onResults(onHandResults);
            
            // Loop camera feed into MediaPipe
            const camera = new Camera(video, {
                onFrame: async () => {
                    await hands.send({image: video});
                },
                width: 640,
                height: 480
            });
            camera.start();
        }

        function onHandResults(results) {
            if (results.multiHandLandmarks && results.multiHandLandmarks.length > 0) {
                cursor.style.display = 'block';
                const landmarks = results.multiHandLandmarks[0];
                
                // Get Index Tip (8) and Thumb Tip (4)
                const indexTip = landmarks[8];
                const thumbTip = landmarks[4];

                // Map MediaPipe normalized coordinates (0 to 1) to screen pixels
                // Note: The camera image is mirrored or scaled, so we map directly to window size
                const screenX = indexTip.x * window.innerWidth;
                const screenY = indexTip.y * window.innerHeight;

                cursor.style.left = `${screenX}px`;
                cursor.style.top = `${screenY}px`;

                // Calculate distance between thumb and index for PINCH
                const distance = Math.hypot(indexTip.x - thumbTip.x, indexTip.y - thumbTip.y);
                
                // Threshold for a pinch
                if (distance < 0.05 && !isPinching) {
                    isPinching = true;
                    cursor.classList.add('pinched');
                    triggerVirtualClick(screenX, screenY);
                } else if (distance > 0.08) {
                    isPinching = false;
                    cursor.classList.remove('pinched');
                }
            } else {
                cursor.style.display = 'none';
            }
        }

        function triggerVirtualClick(x, y) {
            // Temporarily hide cursor so it doesn't block the element underneath
            cursor.style.display = 'none'; 
            
            // Find what widget/button is at the physical coordinates of the pinch
            const element = document.elementFromPoint(x, y);
            
            if (element) {
                // If the element or its parent is a button, trigger a click event
                if (element.tagName === 'BUTTON' || element.classList.contains('sao-btn')) {
                    element.click();
                    // Add visual feedback
                    element.classList.add('active-click');
                    setTimeout(() => element.classList.remove('active-click'), 200);
                }
            }
            // Restore cursor
            cursor.style.display = 'block';
        }
    </script>
</body>
</html>

